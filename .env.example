ELIZA_RAG_LLM_PROVIDER=openai
ELIZA_RAG_LLM_BASE_URL=https://api.openai.com/v1
ELIZA_RAG_LLM_MODEL=gpt-5-mini
ELIZA_RAG_OPENAI_API_KEY=
# For OpenRouter answer mode, switch provider, base URL, model, and key:
# ELIZA_RAG_LLM_PROVIDER=openrouter
# ELIZA_RAG_LLM_BASE_URL=https://openrouter.ai/api/v1
# ELIZA_RAG_LLM_MODEL=openai/gpt-5-mini
# ELIZA_RAG_OPENROUTER_API_KEY=
#
# Backward-compatible shared hosted-answer key still recognized:
# ELIZA_RAG_LLM_API_KEY=
# For local Ollama answer mode, switch provider and set the active model here:
# ELIZA_RAG_LLM_PROVIDER=local_ollama
# ELIZA_RAG_LLM_BASE_URL=http://127.0.0.1:11434/v1
# ELIZA_RAG_LLM_MODEL=qwen2.5:3b-instruct
#
# For OpenRouter-backed judge evaluation:
# ELIZA_RAG_JUDGE_PROVIDER=openrouter
# ELIZA_RAG_JUDGE_BASE_URL=https://openrouter.ai/api/v1
# ELIZA_RAG_JUDGE_API_KEY=
# ELIZA_RAG_JUDGE_MODEL=qwen/qwen3.6-plus:free
ELIZA_RAG_LOCAL_LLM_RUNTIME=ollama
ELIZA_RAG_LOCAL_LLM_RUNTIME_COMMAND=ollama
ELIZA_RAG_LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
ELIZA_RAG_LOCAL_LLM_MODEL=qwen2.5:3b-instruct
ELIZA_RAG_LOCAL_LLM_START_TIMEOUT_SECONDS=45
# `ELIZA_RAG_LOCAL_LLM_BASE_URL` and `ELIZA_RAG_LOCAL_LLM_MODEL` remain available as
# local-Ollama compatibility aliases and for the standalone runtime helper.
# Backward-compatible aliases still recognized:
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_MODEL=gpt-5-mini
ELIZA_RAG_CORPUS_DIR=./edgar_corpus
ELIZA_RAG_CORPUS_ZIP=./edgar_corpus.zip
ELIZA_RAG_DATA_DIR=./data
ELIZA_RAG_ARTIFACTS_DIR=./artifacts
ELIZA_RAG_CHUNK_SIZE_TOKENS=800
ELIZA_RAG_CHUNK_OVERLAP_TOKENS=100
ELIZA_RAG_RETRIEVAL_TOP_K=8
ELIZA_RAG_ANSWER_TOP_K=6
